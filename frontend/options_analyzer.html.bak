async function loadVolWeather(signal) {
  const data = await apiFetch('/api/vol_structure', signal);
  const el = document.getElementById('m7-content');
  if (!data?.data?.length) { el.innerHTML = '<div class="error-state"><div class="error-icon">⚠</div>Données indisponibles</div>'; return; }

  const terms = data.data.slice(0, 8);
  const nearIV = terms[0]?.iv || 0;
  const icon = nearIV > 80 ? '⛈' : nearIV > 60 ? '🌩' : nearIV > 45 ? '🌧' : nearIV > 30 ? '⛅' : '☀️';
  const label = nearIV > 80 ? 'Volatilité Extrême' : nearIV > 60 ? 'Volatilité Haute' : nearIV > 45 ? 'Volatilité Élevée' : nearIV > 30 ? 'Volatilité Modérée' : 'Volatilité Basse';
  const desc = nearIV > 60 ? 'Marché sous tension — spreads élargis, prudence sur les positions directionnelles.'
             : nearIV > 40 ? 'Volatilité présente — opportunités options mais gestion du risque requise.'
             : 'Marché calme — coût des options faible, favorable aux achats de protection.';

  const termCards = terms.map(t => `
    <div class="vol-term-item">
      <div class="vol-term-expiry">${t.expiry}</div>
      <div class="vol-term-iv" style="color:${t.iv > 60 ? 'var(--red)' : t.iv > 40 ? 'var(--yellow)' : 'var(--green)'}">${t.iv?.toFixed(1)}%</div>
      <div class="vol-term-oi">${t.oi_pct?.toFixed(1)}% OI</div>
    </div>`).join('');

  el.innerHTML = `
    <div class="vol-weather">
      <div class="vol-icon">${icon}</div>
      <div class="vol-info">
        <div class="vol-label">IV Term Structure</div>
        <div class="vol-value" style="color:${nearIV > 60 ? 'var(--red)' : nearIV > 40 ? 'var(--yellow)' : 'var(--green)'}">${nearIV?.toFixed(1)}%</div>
        <div class="vol-desc">${label} — ${desc}</div>
      </div>
    </div>
    <div class="vol-term-grid">${termCards}</div>
  `;
}

