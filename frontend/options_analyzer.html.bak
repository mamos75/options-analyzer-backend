<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mamos Options — BTC Analysis</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #070c18;
    --surface: #0d1525;
    --card: #111a2e;
    --green: #00d47e;
    --red: #ff3c6b;
    --yellow: #f5a623;
    --blue: #3d8eff;
    --purple: #9b6bff;
    --text: #e8eaf0;
    --muted: #5a6478;
    --border: rgba(255,255,255,0.06);
    --border-hover: rgba(255,255,255,0.12);
  }

  html { font-size: 16px; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.85); }
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes barFill {
    from { width: 0%; }
    to { width: var(--target-width); }
  }
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  @keyframes glow-green {
    0%, 100% { box-shadow: 0 0 8px rgba(0,212,126,0.3); }
    50% { box-shadow: 0 0 24px rgba(0,212,126,0.7); }
  }

  /* ─── OVERLAY SCREENS ─── */
  .overlay-screen {
    position: fixed; inset: 0;
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    z-index: 1000;
    animation: fadeIn 0.4s ease;
  }
  .overlay-screen.hidden { display: none; }

  .auth-box {
    width: 100%; max-width: 440px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 48px 40px;
    margin: 16px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
    animation: fadeIn 0.5s ease;
  }

  .auth-logo {
    text-align: center;
    margin-bottom: 32px;
  }
  .auth-logo-mark {
    display: inline-flex; align-items: center; justify-content: center;
    width: 64px; height: 64px;
    background: linear-gradient(135deg, var(--blue), var(--purple));
    border-radius: 16px;
    font-size: 28px; font-weight: 900;
    color: #fff;
    margin-bottom: 16px;
    box-shadow: 0 8px 32px rgba(61,142,255,0.4);
  }
  .auth-title {
    font-size: 24px; font-weight: 800;
    color: #fff;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }
  .auth-subtitle {
    font-size: 13px; color: var(--muted);
    font-weight: 400;
  }

  .btn-patreon {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%;
    background: linear-gradient(135deg, #f96854, #e85d42);
    color: #fff;
    border: none; border-radius: 12px;
    padding: 14px 20px;
    font-size: 15px; font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(249,104,84,0.4);
    margin-bottom: 24px;
  }
  .btn-patreon:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 32px rgba(249,104,84,0.5);
  }
  .btn-patreon:active { transform: translateY(0); }

  .divider {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 24px; color: var(--muted); font-size: 12px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 1px;
  }
  .divider::before, .divider::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }

  .form-group { margin-bottom: 14px; }
  .form-label { display: block; font-size: 12px; font-weight: 600; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
  .form-input {
    width: 100%;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 11px 14px;
    font-size: 14px; font-family: 'Inter', sans-serif;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }
  .form-input:focus { border-color: var(--blue); }
  .form-input::placeholder { color: var(--muted); }

  .btn-login {
    width: 100%;
    background: var(--blue);
    color: #fff; border: none; border-radius: 10px;
    padding: 12px; font-size: 14px; font-weight: 700;
    cursor: pointer; transition: background 0.2s, transform 0.1s;
    font-family: 'Inter', sans-serif;
    margin-top: 4px;
  }
  .btn-login:hover { background: #5a9fff; }
  .btn-login:active { transform: scale(0.99); }

  .auth-note { text-align: center; font-size: 12px; color: var(--muted); margin-top: 20px; }
  .auth-error { background: rgba(255,60,107,0.12); border: 1px solid rgba(255,60,107,0.3); border-radius: 8px; padding: 10px 14px; font-size: 13px; color: var(--red); margin-bottom: 14px; display: none; }
  .auth-error.visible { display: block; }

  /* Upgrade wall */
  .upgrade-badge {
    display: inline-block;
    background: rgba(155,107,255,0.15);
    border: 1px solid rgba(155,107,255,0.3);
    color: var(--purple);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 12px; font-weight: 600;
    margin-bottom: 16px;
  }
  .btn-upgrade {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, var(--purple), var(--blue));
    color: #fff; border: none; border-radius: 12px;
    padding: 14px 28px; font-size: 15px; font-weight: 700;
    cursor: pointer; text-decoration: none;
    box-shadow: 0 4px 20px rgba(155,107,255,0.4);
    margin-top: 8px;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn-upgrade:hover { transform: translateY(-1px); box-shadow: 0 8px 32px rgba(155,107,255,0.5); }
  .upgrade-plan-pill {
    background: rgba(245,166,35,0.12);
    border: 1px solid rgba(245,166,35,0.3);
    color: var(--yellow);
    border-radius: 20px; padding: 4px 12px;
    font-size: 12px; font-weight: 600;
    display: inline-block; margin-bottom: 16px;
  }

  /* ─── LOADING SCREEN ─── */
  #loading-screen {
    position: fixed; inset: 0; background: var(--bg);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    z-index: 999;
  }
  #loading-screen.hidden { display: none; }
  .loader-ring {
    width: 48px; height: 48px;
    border: 3px solid var(--border);
    border-top-color: var(--blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-bottom: 16px;
  }
  .loader-text { font-size: 13px; color: var(--muted); }

  /* ─── MAIN DASHBOARD ─── */
  #dashboard { display: none; min-height: 100vh; }
  #dashboard.visible { display: block; }

  /* ─── HEADER ─── */
  .header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(7,12,24,0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px;
  }

  .header-logo {
    font-size: 15px; font-weight: 900; letter-spacing: 2px;
    color: #fff; flex-shrink: 0;
    background: linear-gradient(90deg, var(--blue), var(--purple));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .header-price {
    font-size: 22px; font-weight: 800;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.5px;
    transition: color 0.3s;
  }
  .header-price.up { color: var(--green); }
  .header-price.down { color: var(--red); }
  .header-price.neutral { color: var(--text); }

  .header-right {
    display: flex; align-items: center; gap: 14px; flex-shrink: 0;
  }

  .live-indicator {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 600; color: var(--green);
  }
  .live-dot {
    width: 8px; height: 8px; background: var(--green);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  .countdown {
    font-size: 11px; color: var(--muted); font-variant-numeric: tabular-nums;
  }

  .btn-logout {
    background: var(--card); border: 1px solid var(--border);
    color: var(--muted); border-radius: 8px;
    padding: 6px 12px; font-size: 12px; font-weight: 600;
    cursor: pointer; font-family: 'Inter', sans-serif;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-logout:hover { border-color: var(--red); color: var(--red); }

  /* ─── MAIN CONTENT ─── */
  .main {
    max-width: 1280px; margin: 0 auto;
    padding: 28px 24px 48px;
    display: flex; flex-direction: column; gap: 20px;
  }

  /* ─── CARDS ─── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--border-hover); }

  .card-inner {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
  }

  .card-label {
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--muted);
    margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
  }
  .card-label-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--blue); flex-shrink: 0;
  }

  /* ─── REGIME SUMMARY TOP CARD ─── */
  .regime-top-hero { display:flex; align-items:center; gap:16px; margin-bottom:16px; flex-wrap:wrap; }
  .regime-top-badge { display:inline-flex; align-items:center; gap:8px;
    border-radius:30px; padding:8px 18px; border:1.5px solid; font-size:13px; font-weight:800;
    letter-spacing:.5px; text-transform:uppercase; }
  .regime-top-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
  .regime-top-urgency { font-size:10px; font-weight:700; letter-spacing:1.2px;
    text-transform:uppercase; padding:3px 10px; border-radius:20px; border:1px solid; }
  .regime-signals-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:14px; }
  .regime-signal-mini { background:rgba(255,255,255,.03); border:1px solid var(--border);
    border-radius:10px; padding:10px 12px; }
  .regime-signal-mini-name { font-size:9px; font-weight:700; text-transform:uppercase;
    letter-spacing:.8px; color:var(--muted); margin-bottom:4px; }
  .regime-signal-mini-val { font-size:14px; font-weight:800; font-variant-numeric:tabular-nums; }
  .regime-signal-mini-trend { font-size:10px; color:var(--muted); margin-top:2px; }
  .regime-plain-text { font-size:13px; color:#c9d1e0; line-height:1.7; margin-bottom:12px; }
  .regime-advice-bar { padding:10px 14px; border-radius:10px; border-left:3px solid;
    background:rgba(255,255,255,.03); }
  .regime-advice-label { font-size:9px; font-weight:700; text-transform:uppercase;
    letter-spacing:.8px; margin-bottom:4px; }
  .regime-advice-text { font-size:12px; color:#b0bec5; line-height:1.6; }

  /* ─── MODULE 1: SIGNAL PRINCIPAL ─── */
  .signal-hero {
    display: flex; flex-direction: column; gap: 8px;
    animation: fadeIn 0.5s ease;
  }
  .signal-direction {
    font-size: 52px; font-weight: 900; letter-spacing: -2px;
    line-height: 1;
  }
  .signal-direction.haussier { color: var(--green); }
  .signal-direction.baissier { color: var(--red); }
  .signal-direction.neutre { color: var(--yellow); }

  .signal-conviction {
    display: flex; align-items: center; gap: 12px;
    margin-top: 8px;
  }
  .conviction-bar-wrap {
    flex: 1; max-width: 240px;
    background: var(--card); border-radius: 4px; height: 6px; overflow: hidden;
  }
  .conviction-bar {
    height: 100%; border-radius: 4px;
    transition: width 1s cubic-bezier(0.4,0,0.2,1);
  }
  .conviction-label { font-size: 13px; font-weight: 600; color: var(--muted); }
  .conviction-pct { font-size: 20px; font-weight: 800; }

  .signal-watch {
    font-size: 14px; color: rgba(232,234,240,0.7);
    margin-top: 6px; font-weight: 400;
    max-width: 600px;
  }

  .warnings-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .warning-pill {
    background: rgba(245,166,35,0.12);
    border: 1px solid rgba(245,166,35,0.25);
    color: var(--yellow);
    border-radius: 20px; padding: 4px 12px;
    font-size: 11px; font-weight: 600;
  }

  /* ─── MODULE 2: NIVEAUX CLÉS ─── */
  .levels-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .level-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: transform 0.2s, border-color 0.2s;
  }
  .level-card:hover { transform: translateY(-2px); }
  .level-card.support { border-top: 2px solid var(--green); }
  .level-card.pivot { border-top: 2px solid var(--yellow); }
  .level-card.resistance { border-top: 2px solid var(--red); }

  .level-type { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 8px; }
  .level-card.support .level-type { color: var(--green); }
  .level-card.pivot .level-type { color: var(--yellow); }
  .level-card.resistance .level-type { color: var(--red); }

  .level-price {
    font-size: 28px; font-weight: 800; letter-spacing: -1px;
    font-variant-numeric: tabular-nums;
    margin-bottom: 4px;
  }
  .level-card.support .level-price { color: var(--green); }
  .level-card.pivot .level-price { color: var(--yellow); }
  .level-card.resistance .level-price { color: var(--red); }

  .level-tag {
    font-size: 11px; color: var(--muted); font-weight: 500;
  }

  .levels-meta {
    display: flex; gap: 16px; margin-top: 14px; flex-wrap: wrap;
  }
  .levels-meta-item {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 16px;
    font-size: 12px;
  }
  .levels-meta-item span:first-child { color: var(--muted); margin-right: 6px; }
  .levels-meta-item span:last-child { font-weight: 700; font-variant-numeric: tabular-nums; }

  /* ─── MODULE 3: PROBABILITÉS ─── */
  .prob-grid {
    display: flex; flex-direction: column; gap: 14px;
  }
  .prob-item {}
  .prob-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 7px;
  }
  .prob-label { font-size: 13px; font-weight: 600; }
  .prob-pct { font-size: 15px; font-weight: 800; font-variant-numeric: tabular-nums; }
  .prob-bar-wrap {
    height: 8px; background: var(--card); border-radius: 4px; overflow: hidden;
  }
  .prob-bar {
    height: 100%; border-radius: 4px;
    width: 0%;
    transition: width 1.2s cubic-bezier(0.4,0,0.2,1);
  }
  .prob-bar.bull { background: linear-gradient(90deg, var(--green), rgba(0,212,126,0.6)); }
  .prob-bar.bear { background: linear-gradient(90deg, var(--red), rgba(255,60,107,0.6)); }

  /* ─── MODULE 4: CONTEXTE ─── */
  .context-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
  }
  .context-pill {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 16px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .context-pill-label { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); }
  .context-pill-value { font-size: 18px; font-weight: 800; }
  .context-pill-sub { font-size: 11px; color: var(--muted); }

  /* ─── MODULES 3+4 SIDE BY SIDE ─── */
  .dual-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  /* ─── MODULE 5: NARRATIVE ─── */
  .narrative-phrase {
    font-size: 16px; font-weight: 500; line-height: 1.7;
    color: var(--text); margin-bottom: 16px;
  }
  .narrative-banner {
    background: rgba(245,166,35,0.08);
    border: 1px solid rgba(245,166,35,0.2);
    border-radius: 10px; padding: 12px 16px;
    font-size: 13px; color: var(--yellow); font-weight: 500;
    margin-bottom: 16px;
  }
  .narrative-levels {
    display: flex; gap: 10px; flex-wrap: wrap;
  }
  .level-chip {
    border-radius: 20px; padding: 4px 14px;
    font-size: 12px; font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .level-chip.up { background: rgba(0,212,126,0.12); border: 1px solid rgba(0,212,126,0.3); color: var(--green); }
  .level-chip.down { background: rgba(255,60,107,0.12); border: 1px solid rgba(255,60,107,0.3); color: var(--red); }

  /* ─── MODULE 6: MODÈLE ACTIF ─── */
  .model-row {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .model-name {
    font-size: 18px; font-weight: 800; color: var(--blue);
    flex-shrink: 0;
  }
  .model-stats {
    display: flex; gap: 20px; flex-wrap: wrap;
  }
  .model-stat { font-size: 13px; }
  .model-stat span:first-child { color: var(--muted); margin-right: 4px; }
  .model-stat span:last-child { font-weight: 700; }

  /* ─── BLUR / LOCK OVERLAY ─── */
  .module-locked {
    position: relative;
  }
  .module-locked .card-content {
    filter: blur(6px);
    pointer-events: none;
    user-select: none;
  }
  .lock-overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 10; gap: 10px;
    background: rgba(7,12,24,0.5);
    border-radius: 16px;
  }
  .lock-icon { font-size: 28px; }
  .lock-text { font-size: 14px; font-weight: 700; color: var(--text); text-align: center; }
  .lock-sub { font-size: 12px; color: var(--muted); }

  /* ─── SKELETON / ERROR ─── */
  .skeleton {
    background: linear-gradient(90deg, var(--card) 25%, #1a2540 50%, var(--card) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 6px;
    height: 20px;
  }
  .skeleton.large { height: 52px; border-radius: 10px; }
  .skeleton.sm { height: 12px; }

  .error-state {
    text-align: center; padding: 24px;
    color: var(--muted); font-size: 13px;
  }
  .error-state .error-icon { font-size: 24px; margin-bottom: 8px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .header-logo { font-size: 12px; letter-spacing: 1px; }
    .header-price { font-size: 18px; }
    .countdown { display: none; }
    .main { padding: 16px 12px 48px; gap: 14px; }
    .card { padding: 16px; }
    .signal-direction { font-size: 36px; }
    .levels-grid { grid-template-columns: 1fr; }
    .dual-grid { grid-template-columns: 1fr; }
    .context-grid { grid-template-columns: 1fr 1fr; }
    .level-price { font-size: 22px; }
    .auth-box { padding: 32px 24px; }
  }


  /* ─── MODULE VEX/CEX ─── */
  .vex-cex-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;
  }
  .vex-cex-box {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 12px; padding: 16px;
  }
  .vex-cex-box-label {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; color: var(--muted); margin-bottom: 8px;
  }
  .vex-cex-value {
    font-size: 22px; font-weight: 800; margin-bottom: 4px;
    font-variant-numeric: tabular-nums;
  }
  .vex-cex-direction {
    font-size: 11px; font-weight: 600; letter-spacing: .5px;
    text-transform: uppercase; margin-bottom: 6px;
  }
  .vex-cex-interp {
    font-size: 11px; color: var(--muted); line-height: 1.5;
  }
  .vex-cex-strikes {
    display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px;
  }
  .vex-cex-chip {
    background: rgba(255,255,255,0.04); border: 1px solid var(--border);
    border-radius: 6px; padding: 3px 8px;
    font-size: 10px; font-weight: 600; font-variant-numeric: tabular-nums;
    color: var(--muted);
  }
  .gamma-flip-box {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 12px; padding: 16px; margin-top: 4px;
  }
  .gamma-flip-label {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; color: var(--muted); margin-bottom: 8px;
  }
  .gamma-flip-price {
    font-size: 20px; font-weight: 800; font-variant-numeric: tabular-nums;
    margin-bottom: 4px;
  }
  .gamma-flip-dist {
    font-size: 12px; font-weight: 600; margin-bottom: 6px;
  }
  .gamma-flip-interp {
    font-size: 11px; color: var(--muted); line-height: 1.55;
  }
  /* ─── VEX/CEX HISTORY CHARTS ─── */
  .vc-history-wrap {
    margin-top: 18px;
  }
  .vc-chart-block {
    margin-bottom: 14px;
  }
  .vc-chart-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 6px;
  }
  .vc-chart-label {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; color: var(--muted);
  }
  .vc-chart-current {
    font-size: 12px; font-weight: 700; font-variant-numeric: tabular-nums;
  }
  .vc-canvas-wrap {
    position: relative; width: 100%; height: 72px;
    background: rgba(255,255,255,0.02); border-radius: 10px; overflow: hidden;
  }
  .vc-canvas-wrap canvas {
    display: block; width: 100%; height: 100%;
  }
  .vc-period-row {
    display: flex; gap: 6px; justify-content: flex-end; margin-bottom: 10px;
  }
  .vc-period-btn {
    background: transparent; border: 1px solid var(--border);
    border-radius: 6px; padding: 3px 10px;
    font-size: 10px; font-weight: 600; color: var(--muted);
    cursor: pointer; transition: all .15s;
  }
  .vc-period-btn.active {
    background: rgba(168,85,247,.15); border-color: var(--purple);
    color: var(--purple);
  }

  /* ─── REGIME DIAGNOSIS ─── */
  .regime-block {
    margin-top: 18px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 20px;
  }
  .regime-header {
    display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
  }
  .regime-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 30px; padding: 5px 14px;
    font-size: 11px; font-weight: 700; letter-spacing: .6px;
    text-transform: uppercase;
  }
  .regime-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
  }
  .regime-title {
    font-size: 10px; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; color: var(--muted);
  }
  .regime-plain {
    font-size: 13px; color: #c9d1e0; line-height: 1.7; margin-bottom: 12px;
  }
  .regime-signals {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
    margin-top: 10px;
  }
  .regime-signal-item {
    background: rgba(255,255,255,0.03); border: 1px solid var(--border);
    border-radius: 8px; padding: 9px 12px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .regime-signal-name {
    font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .5px; color: var(--muted);
  }
  .regime-signal-val {
    font-size: 11px; font-weight: 700;
  }

  @media (max-width: 480px) {
    .header { padding: 0 12px; height: 56px; }
    .header-price { font-size: 15px; }
    .btn-logout { display: none; }
    .context-grid { grid-template-columns: 1fr; }
  }

  /* ─── PERIOD SELECTOR ─── */
  .period-selector { display:flex; gap:4px; margin-left:auto; }
  .period-btn { background:rgba(255,255,255,.06); border:1px solid var(--border); border-radius:8px; padding:3px 10px; font-size:10px; font-weight:700; color:var(--muted); cursor:pointer; letter-spacing:.05em; transition:all .15s; }
  .period-btn:hover { border-color:rgba(255,255,255,.2); color:var(--text); }
  .period-btn.active { background:rgba(61,142,255,.15); border-color:rgba(61,142,255,.5); color:#3d8eff; }

  /* ─── SPARKLINE CANVAS ─── */
  .spark-wrap { position:relative; margin-top:8px; }
  .spark-wrap canvas { width:100%; height:70px; display:block; }
  .spark-label { font-size:10px; color:var(--muted); margin-bottom:4px; font-weight:600; letter-spacing:.05em; }
  .spark-stat { display:flex; justify-content:space-between; align-items:center; margin-top:6px; }
  .spark-stat-val { font-size:13px; font-weight:700; }
  .spark-stat-lbl { font-size:10px; color:var(--muted); }

  /* ─── LEVELS ENRICHED ─── */
  .lvl-section-title { font-size:9px; font-weight:700; letter-spacing:.1em; color:var(--muted); text-transform:uppercase; margin:12px 0 6px; }
  .lvl-section-title:first-child { margin-top:0; }
  .levels-grid-2 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; }
  .level-card-sm { background:rgba(255,255,255,.04); border:1px solid var(--border); border-radius:10px; padding:8px 10px; }
  .level-card-sm.support { border-color:rgba(0,212,126,.25); }
  .level-card-sm.resistance { border-color:rgba(255,60,107,.25); }
  .level-card-sm.pivot { border-color:rgba(245,166,35,.25); }
  .level-type-sm { font-size:9px; color:var(--muted); font-weight:600; letter-spacing:.06em; text-transform:uppercase; }
  .level-price-sm { font-size:14px; font-weight:800; margin:2px 0; }
  .level-price-sm.support { color:var(--green); }
  .level-price-sm.resistance { color:var(--red); }
  .level-price-sm.pivot { color:var(--yellow); }
  .level-tag-sm { font-size:9px; color:var(--muted); }
  .levels-divider { height:1px; background:var(--border); margin:10px 0; }

  /* ─── VOL WEATHER ─── */
  .vol-weather { display:flex; align-items:center; gap:14px; padding:10px 0 4px; }
  .vol-icon { font-size:36px; line-height:1; }
  .vol-info { flex:1; }
  .vol-label { font-size:11px; color:var(--muted); font-weight:600; letter-spacing:.05em; text-transform:uppercase; }
  .vol-value { font-size:28px; font-weight:900; margin:2px 0; }
  .vol-desc { font-size:11px; color:var(--muted); line-height:1.4; }
  .vol-term-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(80px,1fr)); gap:6px; margin-top:10px; }
  .vol-term-item { background:rgba(255,255,255,.04); border:1px solid var(--border); border-radius:8px; padding:6px 8px; text-align:center; }
  .vol-term-expiry { font-size:9px; color:var(--muted); font-weight:600; }
  .vol-term-iv { font-size:13px; font-weight:800; margin:2px 0; }
  .vol-term-oi { font-size:9px; color:var(--muted); }

  /* ─── GEX/DEX PANEL ─── */
  .gex-dex-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .gex-dex-card { background:rgba(255,255,255,.04); border:1px solid var(--border); border-radius:12px; padding:12px; }
  .gex-dex-title { font-size:10px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin-bottom:4px; }
  .gex-dex-value { font-size:16px; font-weight:900; margin-bottom:8px; }
  .gex-dex-impact { font-size:10px; color:var(--muted); line-height:1.4; margin-top:6px; padding-top:6px; border-top:1px solid var(--border); }

  /* ─── MOPI vs BTC chart ─── */
  .mopi-chart-wrap { position:relative; margin-top:8px; }
  .mopi-chart-wrap canvas { width:100%; height:160px; display:block; }
  .mopi-legend { display:flex; gap:16px; margin-top:8px; }
  .mopi-legend-item { display:flex; align-items:center; gap:6px; font-size:11px; color:var(--muted); }
  .mopi-legend-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .mopi-stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-top:10px; }
  .mopi-stat-box { background:rgba(255,255,255,.04); border:1px solid var(--border); border-radius:8px; padding:8px; text-align:center; }
  .mopi-stat-lbl { font-size:9px; color:var(--muted); font-weight:600; letter-spacing:.05em; text-transform:uppercase; }
  .mopi-stat-val { font-size:15px; font-weight:800; margin-top:2px; }
/* ── Stale data indicators (Phase 2) ── */
[data-stale=1] { opacity: 0.6; position: relative; }
[data-stale=1]::after {
  content: 'Données périmées';
  position: absolute;
  top: 6px; right: 8px;
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .6px;
  color: #f59e0b;
  background: #f59e0b18;
  border: 1px solid #f59e0b44;
  border-radius: 6px;
  padding: 2px 6px;
  pointer-events: none;
}
#api-error-banner {
  display: none;
  background: #ef444418;
  border: 1px solid #ef444455;
  border-radius: 10px;
  padding: 10px 16px;
  margin: 0 0 12px;
  font-size: 12px;
  color: #fca5a5;
}
#api-error-banner.visible { display: block; }
</style>
</head>
<body>

<!-- ─── LOADING ─── -->
<div id="loading-screen">
  <div class="loader-ring"></div>
  <div class="loader-text">Vérification de l'accès…</div>
</div>

<!-- ─── LOGIN WALL ─── -->
<div id="login-wall" class="overlay-screen hidden">
  <div class="auth-box">
    <div class="auth-logo">
      <div class="auth-logo-mark">M</div>
      <div class="auth-title">Mamos Options</div>
      <div class="auth-subtitle">Réservé aux membres Mamos Elite</div>
    </div>
    <div class="auth-error" id="login-error"></div>
    <button class="btn-patreon" onclick="loginWithPatreon()">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M14.82 2.41C18.78 2.41 22 5.65 22 9.62C22 13.58 18.78 16.8 14.82 16.8C10.85 16.8 7.61 13.58 7.61 9.62C7.61 5.65 10.85 2.41 14.82 2.41ZM2 21.6H5.5V2.41H2V21.6Z" fill="white"/>
      </svg>
      Continuer avec Patreon
    </button>
    <div class="divider">OU</div>
    <form id="legacy-login-form" onsubmit="handleLegacyLogin(event)">
      <div class="form-group">
        <label class="form-label" for="login-email">Email</label>
        <input class="form-input" type="email" id="login-email" placeholder="votre@email.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label" for="login-password">Mot de passe</label>
        <input class="form-input" type="password" id="login-password" placeholder="••••••••" required autocomplete="current-password">
      </div>
      <button class="btn-login" type="submit" id="login-btn">Se connecter</button>
    </form>
    <div class="auth-note">Accès via abonnement Patreon Mamos Elite</div>
  </div>
</div>

<!-- ─── UPGRADE WALL ─── -->
<div id="upgrade-wall" class="overlay-screen hidden">
  <div class="auth-box" style="text-align:center;">
    <div class="auth-logo-mark" style="margin:0 auto 16px;">M</div>
    <div class="auth-title" style="margin-bottom:8px;">Accès restreint</div>
    <div id="current-plan-display" class="upgrade-plan-pill">Plan: Mamos Basic</div>
    <p style="font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:24px;margin-top:8px;">
      Mamos Options est exclusivement disponible pour les membres <strong style="color:var(--purple);">Mamos Elite</strong>.<br>
      Passe au niveau Elite pour accéder à l'analyse complète des options BTC en temps réel.
    </p>
    <a class="btn-upgrade" href="https://www.patreon.com/mamoscrypto" target="_blank">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M14.82 2.41C18.78 2.41 22 5.65 22 9.62C22 13.58 18.78 16.8 14.82 16.8C10.85 16.8 7.61 13.58 7.61 9.62C7.61 5.65 10.85 2.41 14.82 2.41ZM2 21.6H5.5V2.41H2V21.6Z" fill="white"/>
      </svg>
      Passer à Mamos Elite
    </a>
    <br><br>
    <button class="btn-logout" style="margin:0 auto;" onclick="logout()">Se déconnecter</button>
  </div>
</div>

<!-- ─── DASHBOARD ─── -->
<div id="dashboard">
  <div id="api-error-banner"></div>

  <!-- HEADER -->
  <header class="header">
    <div class="header-logo">MAMOS OPTIONS</div>
    <div class="header-price neutral" id="btc-price">—</div>
    <div class="header-right">
      <div class="live-indicator">
        <div class="live-dot"></div>
        <span>LIVE</span>
      </div>
      <div class="countdown" id="refresh-countdown">—</div>
      <button class="btn-logout" onclick="logout()">Déconnexion</button>
    </div>
  </header>

  <!-- MAIN -->
  <main class="main">

    <!-- CARD RÉGIME — SYNTHÈSE DESK OPTIONS -->
    <div class="card" id="regime-summary-card">
      <div class="card-label">
        <div class="card-label-dot" id="regime-dot-indicator" style="background:#94a3b8"></div>
        RÉGIME DE MARCHÉ — SYNTHÈSE DESK OPTIONS
      </div>
      <div id="regime-summary-content">
        <div class="skeleton" style="height:120px;border-radius:12px;"></div>
      </div>
    </div>

    <!-- MODULE 1: SIGNAL PRINCIPAL -->
    <div class="card" id="m1-signal">
      <div class="card-label"><div class="card-label-dot" style="background:var(--blue)"></div>SIGNAL PRINCIPAL</div>
      <div id="m1-content">
        <div class="skeleton large" style="width:280px;margin-bottom:12px;"></div>
        <div class="skeleton" style="width:200px;"></div>
      </div>
    </div>

    <!-- MODULE 2: NIVEAUX CLÉS (enrichi) -->
    <div class="card" id="m2-levels">
      <div class="card-label"><div class="card-label-dot" style="background:var(--yellow)"></div>NIVEAUX CLÉS</div>
      <div id="m2-content">
        <div class="skeleton" style="height:180px;border-radius:12px;"></div>
      </div>
    </div>

    <!-- MODULES 3 + 4 side by side -->
    <div class="dual-grid">
      <!-- MODULE 3: PROBABILITÉS -->
      <div class="card" id="m3-prob">
        <div class="card-label"><div class="card-label-dot" style="background:var(--green)"></div>PROBABILITÉS</div>
        <div id="m3-content">
          <div class="skeleton" style="height:120px;border-radius:10px;"></div>
        </div>
      </div>

      <!-- MODULE 4: CONTEXTE -->
      <div class="card" id="m4-context">
        <div class="card-label"><div class="card-label-dot" style="background:var(--purple)"></div>CONTEXTE</div>
        <div id="m4-content">
          <div class="skeleton" style="height:120px;border-radius:10px;"></div>
        </div>
      </div>
    </div>

    <!-- MODULE 7: VOL WEATHER -->
    <div class="card" id="m7-vol">
      <div class="card-label"><div class="card-label-dot" style="background:var(--blue)"></div>MÉTÉO VOLATILITÉ</div>
      <div id="m7-content">
        <div class="skeleton" style="height:100px;border-radius:12px;"></div>
      </div>
    </div>

    <!-- MODULE 8: GEX + DEX EVOLUTION -->
    <div class="card" id="m8-gexdex">
      <div class="card-label"><div class="card-label-dot" style="background:var(--purple)"></div>GEX &amp; DEX — ÉVOLUTION
        <div class="period-selector">
          <button class="period-btn active" onclick="setPeriod('7d')">7J</button>
          <button class="period-btn" onclick="setPeriod('14d')">14J</button>
          <button class="period-btn" onclick="setPeriod('30d')">30J</button>
        </div>
      </div>
      <div id="m8-content">
        <div class="skeleton" style="height:180px;border-radius:12px;"></div>
      </div>
    </div>

    <!-- MODULE 9: MOPI vs BTC -->
    <div class="card" id="m9-mopi">
      <div class="card-label"><div class="card-label-dot" style="background:var(--green)"></div>MOPI vs BTC
        <div class="period-selector">
          <button class="period-btn active" onclick="setPeriod('7d')">7J</button>
          <button class="period-btn" onclick="setPeriod('14d')">14J</button>
          <button class="period-btn" onclick="setPeriod('30d')">30J</button>
        </div>
      </div>
      <div id="m9-content">
        <div class="skeleton" style="height:200px;border-radius:12px;"></div>
      </div>
    </div>

    <!-- MODULE 5: NARRATIVE IA -->
    <div class="card" id="m5-narrative">
      <div class="card-label"><div class="card-label-dot" style="background:var(--purple)"></div>NARRATIVE IA</div>
      <div id="m5-content">
        <div class="skeleton" style="margin-bottom:10px;"></div>
        <div class="skeleton" style="width:80%;margin-bottom:10px;"></div>
        <div class="skeleton sm" style="width:60%;"></div>
      </div>
    </div>

    <!-- MODULE 6: MODÈLE ACTIF -->
    <div class="card" id="m6-model">
      <div class="card-label"><div class="card-label-dot" style="background:var(--blue)"></div>MODÈLE ACTIF</div>
      <div id="m6-content">
        <div class="skeleton" style="width:200px;height:28px;border-radius:8px;"></div>
      </div>
    </div>


    <!-- MODULE VEX/CEX: VANNA & CHARM EXPOSURE -->
    <div class="card" id="m-vex-cex">
      <div class="card-label"><div class="card-label-dot" style="background:var(--purple)"></div>VEX / CEX — VANNA &amp; CHARM</div>
      <div id="vex-cex-content">
        <div class="skeleton" style="width:100%;height:80px;border-radius:12px;margin-bottom:12px;"></div>
        <div class="skeleton" style="width:100%;height:80px;border-radius:12px;margin-bottom:12px;"></div>
        <div class="skeleton" style="width:70%;height:40px;border-radius:10px;"></div>
      </div>
    </div>

  </main>
</div>

<script>
// ══════════════════════════════════════════════════
//  CONFIG
// ══════════════════════════════════════════════════
const API_BASE = '';  // same origin
const REFRESH_INTERVAL = 60; // seconds
const ELITE_PLAN = 'Mamos Elite';

// ══════════════════════════════════════════════════
//  AUTH SYSTEM
// ══════════════════════════════════════════════════
let authState = { authenticated: false, isElite: false, plan: null, method: null };
let refreshTimer = null;
let countdownInterval = null;
let secondsLeft = REFRESH_INTERVAL;

async function checkAuth() {
  // 1. Check mamos_trading_session (set by trading.mamoscrypto.com after Patreon OAuth)
  try {
    const sessionRaw = localStorage.getItem('mamos_trading_session');
    if (sessionRaw) {
      const session = JSON.parse(sessionRaw);
      if (session && session.plan && session.premium_active !== false) {
        authState = {
          authenticated: true,
          isElite: session.plan === ELITE_PLAN,
          plan: session.plan,
          method: 'patreon'
        };
        return authState;
      }
    }
  } catch(e) {}

  // 2. Check legacy JWT token
  try {
    const legacyToken = localStorage.getItem('mamos_auth_v1');
    if (legacyToken) {
      const resp = await fetch('/api/auth/verify', {
        headers: { 'Authorization': 'Bearer ' + legacyToken }
      });
      if (resp.ok) {
        const data = await resp.json();
        authState = {
          authenticated: true,
          isElite: data.plan === ELITE_PLAN,
          plan: data.plan || 'Mamos Basic',
          method: 'legacy'
        };
        return authState;
      }
    }
  } catch(e) {}

  authState = { authenticated: false, isElite: false, plan: null, method: null };
  return authState;
}

function loginWithPatreon() {
  window.location.href = 'https://ncltwnrrzrqtxgxchnaf.supabase.co/functions/v1/patreon-oauth/start?app_url=' + encodeURIComponent('https://options-analyzer.mamoscrypto.com');
}

async function handleLegacyLogin(e) {
  e.preventDefault();
  const btn = document.getElementById('login-btn');
  const errEl = document.getElementById('login-error');
  const email = document.getElementById('login-email').value;
  const password = document.getElementById('login-password').value;

  btn.textContent = 'Connexion…';
  btn.disabled = true;
  errEl.classList.remove('visible');

  try {
    const resp = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password })
    });
    const data = await resp.json();
    if (resp.ok && data.token) {
      localStorage.setItem('mamos_auth_v1', data.token);
      await initApp();
    } else {
      errEl.textContent = data.error || 'Identifiants incorrects';
      errEl.classList.add('visible');
    }
  } catch(e) {
    errEl.textContent = 'Erreur de connexion au serveur';
    errEl.classList.add('visible');
  }

  btn.textContent = 'Se connecter';
  btn.disabled = false;
}

function logout() {
  localStorage.removeItem('mamos_trading_session');
  localStorage.removeItem('mamos_auth_v1');
  authState = { authenticated: false, isElite: false, plan: null, method: null };
  if (countdownInterval) clearInterval(countdownInterval);
  if (refreshTimer) clearInterval(refreshTimer);
  showScreen('login');
}

function showScreen(screen) {
  document.getElementById('loading-screen').classList.add('hidden');
  document.getElementById('login-wall').classList.add('hidden');
  document.getElementById('upgrade-wall').classList.add('hidden');
  document.getElementById('dashboard').classList.remove('visible');

  if (screen === 'login') {
    document.getElementById('login-wall').classList.remove('hidden');
  } else if (screen === 'upgrade') {
    document.getElementById('current-plan-display').textContent = 'Plan: ' + (authState.plan || 'Mamos Basic');
    document.getElementById('upgrade-wall').classList.remove('hidden');
  } else if (screen === 'dashboard') {
    document.getElementById('dashboard').classList.add('visible');
  }
}

async function initApp() {
  // Handle Patreon OAuth callback — hash can contain:
  // 1. #mamos_session=<base64> (from trading.mamoscrypto.com redirect, legacy)
  // 2. #access_token=<jwt>&... (from Supabase magic link after direct Patreon OAuth)
  try {
    const hash = window.location.hash;

    if (hash.includes('mamos_session=')) {
      const match = hash.match(/mamos_session=([^&]+)/);
      if (match) {
        const decoded = JSON.parse(atob(match[1]));
        if (decoded && decoded.plan) {
          localStorage.setItem('mamos_trading_session', JSON.stringify({
            plan: decoded.plan,
            email: decoded.email || '',
            premium_active: true,
            ts: decoded.ts || Date.now()
          }));
        }
      }
      history.replaceState(null, '', window.location.pathname + window.location.search);

    } else if (hash.includes('access_token=')) {
      // Direct Patreon OAuth callback — extract JWT and fetch user metadata
      const params = new URLSearchParams(hash.slice(1));
      const accessToken = params.get('access_token');
      if (accessToken) {
        // Fetch user info from Supabase using the access token
        const resp = await fetch('https://ncltwnrrzrqtxgxchnaf.supabase.co/auth/v1/user', {
          headers: {
            'Authorization': 'Bearer ' + accessToken,
            'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5jbHR3bnJyenJxdHhneGNobmFmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYwNjY4OTIsImV4cCI6MjA5MTY0Mjg5Mn0.JShY8xzrBpErlfrdXt2PuuByZ1Zy9oaKNU6IvAhCArY'
          }
        });
        if (resp.ok) {
          const user = await resp.json();
          const plan = user.user_metadata?.plan ?? '';
          const email = user.email ?? '';
          if (plan) {
            localStorage.setItem('mamos_trading_session', JSON.stringify({
              plan,
              email,
              premium_active: user.user_metadata?.premium_active === true,
              ts: Date.now()
            }));
          }
        }
      }
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }
  } catch(e) {}

  document.getElementById('loading-screen').classList.remove('hidden');
  document.getElementById('login-wall').classList.add('hidden');
  document.getElementById('upgrade-wall').classList.add('hidden');
  document.getElementById('dashboard').classList.remove('visible');

  const auth = await checkAuth();
  document.getElementById('loading-screen').classList.add('hidden');

  if (!auth.authenticated) {
    showScreen('login');
    return;
  }
  if (!auth.isElite) {
    showScreen('upgrade');
    // Apply blur to legacy free users who sneak past
    applyLockToModules();
    return;
  }

  showScreen('dashboard');
  await loadAllData();
  startRefreshLoop();
}

// ══════════════════════════════════════════════════
//  LOCK OVERLAY (for non-Elite legacy users)
// ══════════════════════════════════════════════════
function applyLockToModules() {
  const ids = ['m2-levels','m3-prob','m4-context','m5-narrative','m6-model'];
  ids.forEach(id => {
    const card = document.getElementById(id);
    if (!card) return;
    card.classList.add('module-locked');
    const content = card.querySelector('[id$="-content"]');
    if (content) content.classList.add('card-content');
    if (!card.querySelector('.lock-overlay')) {
      const overlay = document.createElement('div');
      overlay.className = 'lock-overlay';
      overlay.innerHTML = `
        <div class="lock-icon">🔒</div>
        <div class="lock-text">Mamos Elite requis</div>
        <div class="lock-sub">Passe à Elite sur Patreon</div>
      `;
      card.appendChild(overlay);
    }
  });
}

// ══════════════════════════════════════════════════
//  API FETCH
// ══════════════════════════════════════════════════
function getAuthHeaders() {
  const headers = { 'Content-Type': 'application/json' };
  const legacyToken = localStorage.getItem('mamos_auth_v1');
  if (legacyToken) headers['Authorization'] = 'Bearer ' + legacyToken;
  return headers;
}

let _fetchSeq = 0;

async function apiFetch(endpoint, signal) {
  try {
    const resp = await fetch(API_BASE + endpoint, { headers: getAuthHeaders(), signal });
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    return await resp.json();
  } catch(e) {
    if (e.name === 'AbortError') return null;
    return null;
  }
}

// ══════════════════════════════════════════════════
//  FORMATTERS
// ══════════════════════════════════════════════════
function fmtPrice(val, decimals) {
  if (val == null) return '—';
  const n = Number(val);
  const d = decimals != null ? decimals : n >= 10000 ? 0 : n >= 1000 ? 1 : 2;
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: d, maximumFractionDigits: d });
}
function fmtPct(val) {
  if (val == null) return '—';
  return Math.round(val) + '%';
}

function formatModelName(slug) {
  if (!slug) return '—';
  return slug
    .replace(/_/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase());
}

// ══════════════════════════════════════════════════
//  BTC PRICE
// ══════════════════════════════════════════════════
let lastBtcPrice = null;
async function loadBtcPrice() {
  try {
    const resp = await fetch('https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT');
    const data = await resp.json();
    const price = parseFloat(data.price);
    const el = document.getElementById('btc-price');
    el.textContent = fmtPrice(price);
    if (lastBtcPrice !== null) {
      el.className = 'header-price ' + (price > lastBtcPrice ? 'up' : price < lastBtcPrice ? 'down' : 'neutral');
    }
    lastBtcPrice = price;
  } catch(e) {
    document.getElementById('btc-price').textContent = '—';
  }
}

// ══════════════════════════════════════════════════
//  MODULE 1: SIGNAL PRINCIPAL
// ══════════════════════════════════════════════════
async function loadSignal(signal) {
  const data = await apiFetch('/api/market_decision', signal);
  const el = document.getElementById('m1-content');
  if (!data) {
    el.innerHTML = `<div class="error-state"><div class="error-icon">⚠</div>Données indisponibles</div>`;
    return;
  }

  const dir = (data.directional?.direction || data.direction || 'NEUTRE').toUpperCase();
  const conf = data.directional?.confidence || data.confidence || 0;
  const watch = data.watch_message || data.message || '';
  const warnings = data.warnings || [];

  let dirClass = 'neutre', dirLabel = 'NEUTRE';
  if (dir.includes('BULL') || dir.includes('HAUSS')) { dirClass = 'haussier'; dirLabel = 'HAUSSIER'; }
  else if (dir.includes('BEAR') || dir.includes('BAISS')) { dirClass = 'baissier'; dirLabel = 'BAISSIER'; }
  else if (dir === 'NEUTRE' || dir === 'NEUTRAL') { dirClass = 'neutre'; dirLabel = 'NEUTRE'; }

  const convColor = dirClass === 'haussier' ? 'var(--green)' : dirClass === 'baissier' ? 'var(--red)' : 'var(--yellow)';

  let warningHTML = '';
  if (warnings.length > 0) {
    warningHTML = '<div class="warnings-row">' +
      warnings.map(w => `<span class="warning-pill">${w}</span>`).join('') +
      '</div>';
  }

  el.innerHTML = `
    <div class="signal-hero">
      <div class="signal-direction ${dirClass}">${dirLabel}</div>
      <div class="signal-conviction">
        <div class="conviction-pct" style="color:${convColor}">${fmtPct(conf)}</div>
        <div class="conviction-label">conviction</div>
        <div class="conviction-bar-wrap">
          <div class="conviction-bar" id="conv-bar" style="background:${convColor};width:0%"></div>
        </div>
      </div>
      ${watch ? `<div class="signal-watch">${watch}</div>` : ''}
      ${warningHTML}
    </div>
  `;

  setTimeout(() => {
    const bar = document.getElementById('conv-bar');
    if (bar) bar.style.width = Math.min(conf, 100) + '%';
  }, 100);

  return data;
}

// ══════════════════════════════════════════════════
//  MODULE 2: NIVEAUX CLÉS
// ══════════════════════════════════════════════════
async function loadLevels(decisionData, signal) {
  const wallsData = await apiFetch('/api/options_walls', signal);
  const el = document.getElementById('m2-content');

  const walls = wallsData || {};

  // Options walls — sort by strike, split supports/resistances
  const price = walls.btc_price || 0;
  const allWalls = (walls.walls || []).slice().sort((a,b) => a.strike - b.strike);
  const supports = allWalls.filter(w => w.strike < price).slice(-3).reverse();
  const resistances = allWalls.filter(w => w.strike > price).slice(0, 3);

  const wallCard = (w, side) => {
    const cls = side === 'support' ? 'support' : 'resistance';
    const tag = w.tag || '';
    const tagColor = tag === 'ACTIONABLE' ? 'var(--green)' : tag === 'STRUCTURAL' ? 'var(--yellow)' : 'var(--muted)';
    return `<div class="level-card-sm ${cls}">
      <div class="level-type-sm">${side === 'support' ? 'Support' : 'Résistance'}</div>
      <div class="level-price-sm ${cls}">${fmtPrice(w.strike)}</div>
      <div class="level-tag-sm" style="color:${tagColor}">${w.type?.replace('_',' ')||''} · ${Math.round(w.total_oi||0).toLocaleString()} BTC</div>
    </div>`;
  };

  el.innerHTML = `
    <div class="lvl-section-title">Murs Options (actifs)</div>
    <div class="levels-grid-2">
      ${resistances.map(w => wallCard(w, 'resistance')).join('')}
      ${supports.map(w => wallCard(w, 'support')).join('')}
    </div>
  `;
}

// ══════════════════════════════════════════════════
//  MODULE 3: PROBABILITÉS
// ══════════════════════════════════════════════════
async function loadProbabilities(signal) {
  const data = await apiFetch('/api/probability_engine', signal);
  const el = document.getElementById('m3-content');

  if (!data) {
    el.innerHTML = `<div class="error-state"><div class="error-icon">⚠</div>Données indisponibles</div>`;
    return;
  }

  const scenarios = [
    { label: 'Hausse 24h', key: 'bull_24h', type: 'bull' },
    { label: 'Baisse 24h', key: 'bear_24h', type: 'bear' },
    { label: 'Hausse 72h', key: 'bull_72h', type: 'bull' },
    { label: 'Baisse 72h', key: 'bear_72h', type: 'bear' },
  ];

  const pctColor = (type) => type === 'bull' ? 'var(--green)' : 'var(--red)';

  let html = '<div class="prob-grid">';
  scenarios.forEach((s, i) => {
    const val = data[s.key]?.probability ?? data[s.key] ?? 0;
    html += `
      <div class="prob-item">
        <div class="prob-header">
          <span class="prob-label">${s.label}</span>
          <span class="prob-pct" style="color:${pctColor(s.type)}">${fmtPct(val)}</span>
        </div>
        <div class="prob-bar-wrap">
          <div class="prob-bar ${s.type}" id="pb-${i}" style="width:0%"></div>
        </div>
      </div>
    `;
  });
  html += '</div>';
  el.innerHTML = html;

  setTimeout(() => {
    scenarios.forEach((s, i) => {
      const val = data[s.key]?.probability ?? data[s.key] ?? 0;
      const bar = document.getElementById('pb-' + i);
      if (bar) bar.style.width = Math.min(val, 100) + '%';
    });
  }, 150);
}

// ══════════════════════════════════════════════════
//  MODULE 4: CONTEXTE
// ══════════════════════════════════════════════════
async function loadContext(signal) {
  const [dashData, dealerData] = await Promise.all([
    apiFetch('/api/dashboard', signal),
    apiFetch('/api/dealer_pressure', signal)
  ]);
  const el = document.getElementById('m4-content');

  const dash = dashData || {};
  const dealer = dealerData || {};

  const volState = dash.weather_state || dash.volatility_state || '—';
  const dealerDir = dealer.direction || '—';
  const mopi = dash.mopi_score ?? dealer.mopi_score ?? null;
  const gex = dash.gex_regime || dealer.gex_regime || '—';

  // Weather state color
  const volColors = {
    'CALME': 'var(--green)',
    'TRANSITION': 'var(--yellow)',
    'EXPLOSIVE': 'var(--red)',
    'CHAOS': 'var(--red)',
  };
  const volColor = volColors[volState] || 'var(--text)';

  // Dealer direction
  let dealerLabel = dealerDir;
  let dealerColor = 'var(--text)';
  if (dealerDir.includes('BEARISH') || dealerDir.includes('BEAR')) {
    dealerLabel = 'Résistance'; dealerColor = 'var(--red)';
  } else if (dealerDir.includes('BULLISH') || dealerDir.includes('BULL')) {
    dealerLabel = 'Support'; dealerColor = 'var(--green)';
  }

  // MOPI color
  let mopiColor = 'var(--text)';
  if (mopi !== null) {
    if (mopi >= 65) mopiColor = 'var(--green)';
    else if (mopi <= 35) mopiColor = 'var(--red)';
    else mopiColor = 'var(--yellow)';
  }

  // GEX color
  const gexColors = { 'AMPLIFICATEUR': 'var(--red)', 'ABSORBEUR': 'var(--green)' };
  const gexColor = gexColors[gex] || 'var(--text)';

  el.innerHTML = `
    <div class="context-grid">
      <div class="context-pill">
        <div class="context-pill-label">Volatilité</div>
        <div class="context-pill-value" style="color:${volColor}">${volState}</div>
        <div class="context-pill-sub">Régime de marché</div>
      </div>
      <div class="context-pill">
        <div class="context-pill-label">Dealer</div>
        <div class="context-pill-value" style="color:${dealerColor}">${dealerLabel}</div>
        <div class="context-pill-sub">Flux dealers</div>
      </div>
      <div class="context-pill">
        <div class="context-pill-label">MOPI</div>
        <div class="context-pill-value" style="color:${mopiColor}">${mopi !== null ? Math.round(mopi) + '/100' : '—'}</div>
        <div class="context-pill-sub">Market Options Pressure</div>
      </div>
      <div class="context-pill">
        <div class="context-pill-label">GEX</div>
        <div class="context-pill-value" style="color:${gexColor}">${gex}</div>
        <div class="context-pill-sub">Gamma Exposure</div>
      </div>
    </div>
  `;
}

